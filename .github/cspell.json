{
  "version": "0.2",
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
  "language": "en,en-GB",
  "dictionaries": ["vgv_allowed", "vgv_forbidden"],
  "dictionaryDefinitions": [
    {
      "name": "vgv_allowed",
      "path": "https://raw.githubusercontent.com/verygoodopensource/very_good_dictionaries/main/allowed.txt",
      "description": "Allowed VGV Spellings"
    },
    {
      "name": "vgv_forbidden",
      "path": "https://raw.githubusercontent.com/verygoodopensource/very_good_dictionaries/main/forbidden.txt",
      "description": "Forbidden VGV Spellings"
    }
  ],
  "useGitignore": true,
  "ignorePaths": [
    "**/*.arb",
    "**/l10n/**",
    "**/firebase_options.dart"
  ],
  "ignoreWords": ["timezone", "meta-data"],
  "words": [
    "gapjyk",
    "merdan",
    "grayscale",
    "grayscales",
    "interword",
    "prefs",
    "swipeable",
    "tesseract",
    "algy",
    "awans",
    "aýlyk",
    "çorba",
    "günortan",
    "jemi",
    "jemy",
    "nahar",
    "sargyt",
    "taksi",
    "türkmen",
    "umumy",
    "всего",
    "итого",
    "русский",
    "сумма",
    "товар"
  ]
}
